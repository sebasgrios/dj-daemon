# Discord application credentials
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optional: register slash commands instantly to a single guild while developing
DISCORD_GUILD_ID=

# Spotify Web API (used only to resolve track metadata; audio is streamed from YouTube)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional path to a yt-dlp binary. Leave empty in Docker (uses the bundled one). For native
# macOS dev, point it to Homebrew's standalone binary: YT_DLP_PATH=/opt/homebrew/bin/yt-dlp
YT_DLP_PATH=
